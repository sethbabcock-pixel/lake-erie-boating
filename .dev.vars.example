# Local dev secrets for `wrangler dev` (Cloudflare Workers). Copy to .dev.vars and fill in.
# MailerSend API token for transactional email (password reset, admin notices).
MAILERSEND_API_KEY=mlsn.xxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override the verified from-address (defaults to noreply@shouldiboat.com).
# EMAIL_FROM=noreply@shouldiboat.com
