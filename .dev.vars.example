# Local dev secrets for `wrangler dev` (Cloudflare Workers). Copy to .dev.vars and fill in.
# Brevo API key for transactional email (password reset, admin notices).
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxx
